# API 프록시(서버). 비우면 코드 기본값(https://quizai-api.onrender.com) 사용
API_SERVER_URL=

# 프록시에서 백엔드 실패 시 목 응답 허용 (기본 true). 프로덕션에서 끄려면 false
ENABLE_PROXY_MOCK_FALLBACK=true

# 클라이언트가 호출하는 API 베이스. 비우면 /api/proxy (권장)
NEXT_PUBLIC_API_URL=

# 퀴즈 WebSocket. 비우면 wss://quizai-api.onrender.com
NEXT_PUBLIC_WS_URL=
